# Copy to .env and adjust for your environment.
#
# Local dev (Postgres from docker-compose, app on host):
# Host port 5433 maps to the container's 5432 (see docker-compose.yml).
DATABASE_URL="postgresql://copilot:copilot@localhost:5433/dispatch?schema=public"
#
# Railway / production: Railway injects DATABASE_URL automatically when you add a
# PostgreSQL plugin. No quotes around the value in Railway's variable editor.

# --- AI service (external) ---------------------------------------------------
# Leave AI_SERVICE_URL unset to use the built-in mock (default; network-free).
# Set it to the ai-service base URL to call the real service over HTTP.
# Inside docker-compose the service is reachable at http://ai-service:8000.
AI_SERVICE_URL=
# Shared bearer secret; must match the ai-service's AI_SERVICE_API_KEY.
AI_SERVICE_API_KEY=
# Client-side timeout in ms (default 8000). A timeout drives Fallback Mode.
AI_SERVICE_TIMEOUT_MS=8000
